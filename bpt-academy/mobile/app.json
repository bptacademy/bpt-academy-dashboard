{
  "expo": {
    "name": "BPT Academy",
    "slug": "mobile",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bptacademy.app",
      "buildNumber": "7",
      "appleTeamId": "R7365964A2",
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIDeviceFamily": [
          1
        ],
        "NSPhotoLibraryUsageDescription": "BPT Academy uses your photo library so you can choose a profile photo. Your photos are only accessed when you tap to change your avatar and are never shared without your permission."
      }
    },
    "android": {
      "package": "com.bptacademy.app",
      "versionCode": 8,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/TTOctosquaresCond-Light.ttf",
            "./assets/fonts/TTOctosquaresCond-Bold.ttf",
            "./assets/fonts/TTOctosquares-Light.ttf",
            "./assets/fonts/TTOctosquaresComp-Regular.ttf",
            "./assets/fonts/TTOctosquaresComp-DBold.ttf"
          ]
        }
      ],
      "expo-video",
      "expo-image-picker",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#16A34A",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a661965b-f384-43fa-8441-f9e5f78a0c3a"
      }
    },
    "owner": "bptacademyuk"
  }
}
